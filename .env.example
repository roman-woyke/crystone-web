# Hostinger Remote MySQL connection (Remote MySQL must be enabled in hPanel).
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Auth.js — generate with `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET="change-me"

# Same invite code the PHP app's config.php defines, so existing invite links
# keep working.
INVITE_CODE="change-me"

# Shared secret between Next.js and the socket.io push server
# (server/realtime.mjs, `npm run realtime`) for the internal /notify endpoint.
REALTIME_INTERNAL_SECRET="change-me"

# Optional realtime overrides (defaults shown):
# REALTIME_PORT=3001
# REALTIME_INTERNAL_URL=http://localhost:3001
# REALTIME_APP_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
